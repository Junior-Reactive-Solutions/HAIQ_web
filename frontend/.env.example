# ── API URL ───────────────────────────────────────────────────
# Local:      http://localhost:3001/v1
# Production: your Render backend URL
VITE_API_BASE_URL=https://haiq-api.onrender.com/v1

# ── Site URL ──────────────────────────────────────────────────
VITE_SITE_URL=https://haiq.ug
