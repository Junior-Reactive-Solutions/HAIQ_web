# ─── Server ────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
SWAGGER_PORT=5010
API_VERSION=v1
TZ=Africa/Kampala

# ─── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/haiq_db
DB_POOL_MAX=10
DB_POOL_IDLE_MS=30000

# ─── JWT ───────────────────────────────────────────────────────
JWT_SECRET=replace_with_64_char_random_string
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=replace_with_different_64_char_string
REFRESH_TOKEN_EXPIRES_IN=7d
ADMIN_JWT_SECRET=replace_with_admin_64_char_string
ADMIN_JWT_EXPIRES_IN=8h

# ─── CORS ──────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# ─── MTN MoMo ──────────────────────────────────────────────────
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_MOMO_SUBSCRIPTION_KEY=your_subscription_key_here
MTN_MOMO_API_USER=your_api_user_uuid
MTN_MOMO_API_KEY=your_api_key_here
MTN_MOMO_CALLBACK_URL=https://api.haiq.ug/v1/payments/mtn/webhook
MTN_MOMO_CALLBACK_SECRET=your_callback_hmac_secret
MTN_MOMO_ENVIRONMENT=sandbox
MTN_MOMO_CURRENCY=UGX
MTN_MOMO_TARGET_ENVIRONMENT=sandbox

# ─── Airtel Money ──────────────────────────────────────────────
AIRTEL_BASE_URL=https://openapi.airtel.africa
AIRTEL_CLIENT_ID=your_client_id
AIRTEL_CLIENT_SECRET=your_client_secret
AIRTEL_MERCHANT_ID=your_merchant_id
AIRTEL_WEBHOOK_SECRET=your_webhook_secret
AIRTEL_COUNTRY=UG
AIRTEL_CURRENCY=UGX

# ─── Bank Transfer ─────────────────────────────────────────────
BANK_ACCOUNT_NAME=HAIQ Bakery Ltd
BANK_ACCOUNT_NUMBER=1234567890
BANK_NAME=Stanbic Bank Uganda
BANK_BRANCH=Kampala Branch
BANK_SWIFT=SBICUGKX

# ─── Cloudinary ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_UPLOAD_PRESET=haiq_products

# ─── Email (Resend) ────────────────────────────────────────────
RESEND_API_KEY=re_your_key_here
EMAIL_FROM=orders@haiq.ug
EMAIL_FROM_NAME=HAIQ Bakery

# ─── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info
LOG_TO_DB=true
LOG_TO_FILE=true

# ─── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
